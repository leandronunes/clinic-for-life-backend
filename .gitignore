# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*
# But keep the example template tracked.
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Ignore key files for decrypting credentials and more.
/config/*.key

# Ignore bundled/vendored gems.
/vendor/bundle
/.bundle/config

# Ignore test coverage and profiling output.
/coverage/
/spec/examples.txt
/test/tmp/*
!/test/tmp/.keep

# Ignore Active Storage uploaded files.
/public/uploads/*
!/public/uploads/.keep
/public/assets

# Ignore dependency manager and tooling caches.
/node_modules/
/.byebug_history
/.ruby-gemset
/.rbenv-vars

# Ignore editor and OS specific files.
.idea/
.vscode/*
!/.vscode/settings.json
!/.vscode/extensions.json
*.swp
*.swo
*~
.DS_Store
Thumbs.db
db/test.sqlite3

# WakaTime local project name override (personal time tracking, not a team convention)
.wakatime-project

# Terraform local state/build artifacts — remote state lives in S3 (see
# infra/terraform/backend.tf); .terraform.lock.hcl IS committed (provider
# version pinning).
infra/terraform/.terraform/
infra/terraform/build/
infra/terraform/terraform.tfvars
infra/terraform/tfplan
*.tfplan
*.tfstate
*.tfstate.*
crash.log
