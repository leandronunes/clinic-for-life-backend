DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=clinic
DATABASE_PASSWORD=clinic

# Secret used to sign JWT tokens. Override in production.
JWT_SECRET=dev_super_secret_change_me

# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173

# AWS S3 — direct video uploads via presigned URLs
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
S3_PRESIGN_EXPIRY=600

# Web Push (VAPID) — notifications to browsers/PWAs. Generate a keypair with:
#   bundle exec ruby -e "require 'web_push'; k = WebPush.generate_key; puts k.public_key; puts k.private_key"
# VAPID_PUBLIC_KEY must also be set as VITE_VAPID_PUBLIC_KEY in the frontend's .env.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:suporte@forlife.app

# Pact contract testing (provider side) — see docs/pact.md.
# Leave PACT_BROKER_BASE_URL unset to verify against a local pact file/directory instead
# (defaults to ./pacts, or set PACT_URL to a specific file path).
PACT_BROKER_BASE_URL=
PACT_BROKER_TOKEN=
PACT_PROVIDER_VERSION=
PACT_PROVIDER_BRANCH=
PACT_PUBLISH_VERIFICATION_RESULTS=false
